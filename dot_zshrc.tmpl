#!/usr/bin/env zsh

stty -ixon

# Set these early in initialization in case something goes sideways
{{ if eq .chezmoi.os "linux" -}}
export XDG_RUNTIME_DIR=/run/user/$(id -u)
{{ end -}}
export EDITOR="emacsclient -a nano"

# Force-update Claude plugins.
export FORCE_AUTOUPDATE_PLUGINS=true

{{ if eq .chezmoi.os "darwin" -}}
# colima's docker socket isn't at the default /var/run/docker.sock path.
export DOCKER_HOST="unix://$HOME/.colima/default/docker.sock"
{{ end -}}

# History
setopt HIST_IGNORE_ALL_DUPS
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000

# Navigation: bare directory names cd into them, and every cd pushes onto the
# dir stack. Use `dirs -v` to inspect, `cd -<TAB>` to jump back.
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt PUSHD_MINUS

# Emacs keybindings
bindkey -e

# Remove path separator from WORDCHARS
WORDCHARS=${WORDCHARS//[\/]}

# Initialize mise first (sets up PATH)
eval "$(~/.local/bin/mise activate zsh)"

# Initialize completion system after mise sets up PATH
autoload -Uz compinit && compinit

# Now load completions (usage CLI will be in PATH)
eval "$(~/.local/bin/mise completion zsh)"
eval "$(chezmoi completion zsh)"

# Initialize starship
eval "$(starship init zsh)"

export GITHUB_PERSONAL_ACCESS_TOKEN="$(gh auth token)"

{{ if eq .chezmoi.os "linux" -}}
# Auto-attach to Zellij on SSH/Mosh login
if [[ -z "$ZELLIJ" ]] && [[ -n "$SSH_CONNECTION" || -n "$SSH_TTY" ]]; then
    # Find a session that's not 'main'
    local session=$(zellij list-sessions --no-formatting 2>/dev/null | grep -v '^main' | head -1 | cut -d' ' -f1)
    if [[ -n "$session" ]]; then
        zellij attach "$session"
    else
        # Only 'main' exists or no sessions - create a new session
        zellij
    fi
    exit
fi
{{ end -}}

alias ls='eza'
alias cat='bat -p'
# find and grep are deliberately NOT aliased to fd/rg — too many scripts, agents,
# and third-party skills emit `grep -E` or `find -type f` and the aliases break
# them silently. Use `fd` and `rg` explicitly when you want them.
alias ccw='claude --allow-dangerously-skip-permissions'
{{ if eq .chezmoi.os "linux" -}}
alias nerdctl='sudo nerdctl --address /run/k3s/containerd/containerd.sock --namespace k8s.io'
alias docker='nerdctl'
{{ end -}}

bindkey "^[[3~" delete-char           # Delete
bindkey "^[[H" beginning-of-line      # Home
bindkey "^[[F" end-of-line            # End

# zsh-autosuggestions - suggestions from history
source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh

# fzf - fuzzy finder keybindings
eval "$(fzf --zsh)"

# fzf customizations
export FZF_DEFAULT_OPTS="
  --height 40%
  --layout=reverse
  --border
"

# Use fd instead of find for fzf (faster, respects .gitignore)
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# Ctrl-T specific options - show file preview
export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"

# Only use uv-managed Python
export UV_MANAGED_PYTHON=1

# Add our local ed25519 key to ssh-agent
ssh-add

# zsh-syntax-highlighting - must be last
source ~/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ if eq .chezmoi.os "linux" -}}
export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
{{ end -}}
