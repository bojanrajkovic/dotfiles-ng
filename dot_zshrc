#!/usr/bin/env zsh

# History
setopt HIST_IGNORE_ALL_DUPS
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000

# Emacs keybindings
bindkey -e

# Remove path separator from WORDCHARS
WORDCHARS=${WORDCHARS//[\/]}

# Initialize mise and starship
eval "$(~/.local/bin/mise activate zsh)"
eval "$(starship init zsh)"

# Auto-attach to Zellij on SSH/Mosh login
if [[ -z "$ZELLIJ" ]] && [[ -n "$SSH_CONNECTION" || -n "$SSH_TTY" ]]; then
    zellij --layout dev attach --create main
fi

alias ls='eza'
alias cat='bat -p'
alias find='fd'
alias grep='rg'

bindkey "^[[3~" delete-char           # Delete
bindkey "^[[H" beginning-of-line      # Home
bindkey "^[[F" end-of-line            # End

# fzf - fuzzy finder keybindings
eval "$(fzf --zsh)"

# fzf customizations
export FZF_DEFAULT_OPTS="
  --height 40%
  --layout=reverse
  --border
  --preview 'bat --color=always --style=numbers --line-range=:500 {}'
"

# Use fd instead of find for fzf (faster, respects .gitignore)
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
