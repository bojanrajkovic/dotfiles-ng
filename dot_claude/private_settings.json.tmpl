{
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://alloy.services.coderinserepeat.com:4318",
    "OTEL_RESOURCE_ATTRIBUTES": "environment=homelab,host={{ .chezmoi.hostname }}",
    "OTEL_METRICS_INCLUDE_VERSION": "true",
    "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE": "cumulative",
    "ENABLE_PROMPT_CACHING_1H": "true",
    "CLAUDE_AFK_TIMEOUT_MS": "86400000"
  },
  "permissions": {
    "allow": [
      "Bash(mise x:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:oxc.rs)",
      "mcp__plugin_serena_serena__list_dir",
      "mcp__plugin_serena_serena__find_file",
      "mcp__plugin_serena_serena__activate_project",
      "Bash(fd:*)",
      "WebFetch(domain:pnpm.io)",
      "WebFetch(domain:antfu.me)",
      "WebFetch(domain:oxc-project.github.io)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__plugin_serena_serena__read_file",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(test:*)",
      "WebFetch(domain:fastify.dev)",
      "WebFetch(domain:vitest.dev)",
      "Bash(git rev-parse:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/no-pipe-test-output.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --style=tui",
    "padding": 0
  },
  "enabledPlugins": {
    "explanatory-output-style@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "elements-of-style@superpowers-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "agent-browser@agent-browser": true,
    "ed3d-research-agents@ed3d-plugins": true,
    "impeccable@impeccable": true
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      },
      "autoUpdate": true
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "ed3d-plugins": {
      "source": {
        "source": "github",
        "repo": "ed3dai/ed3d-plugins"
      },
      "autoUpdate": true
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      },
      "autoUpdate": true
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      },
      "autoUpdate": true
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "editorMode": "normal",
  "preferredNotifChannel": "notifications_disabled",
  "teammateMode": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "voiceEnabled": true
}
